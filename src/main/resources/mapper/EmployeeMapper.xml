<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rui.reggie.mapper.EmployeeMapper">
  <select id="getEmployeeByName" resultType="com.rui.reggie.entity.Employee" parameterType="string">
      select * from employee where name = #{value}
  </select>
</mapper>